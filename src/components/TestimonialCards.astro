---
interface Props {
  name: string;
  text: string;
  rating: number;
  url?: string;
}

const { name, text, rating, url } = Astro.props;

const initials = name
  .split(" ")
  .slice(0, 2)
  .map((w) => w[0])
  .join("")
  .toUpperCase();
---

<article
  class="relative h-full min-h-72 rounded-2xl bg-white p-6 shadow-sm border border-slate-100 flex flex-col gap-4 transition-shadow duration-200 hover:shadow-md"
>
  <!-- Quote mark decorativo -->
  <svg
    aria-hidden="true"
    class="absolute top-5 right-6 w-8 h-8 text-blue-50"
    fill="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"
    />
  </svg>

  <!-- Estrellas -->
  <div class="flex gap-0.5" aria-label={`${rating} de 5 estrellas`}>
    {
      Array.from({ length: 5 }).map((_, i) => (
        <svg
          class={`w-4 h-4 ${i < rating ? "text-amber-400" : "text-slate-200"}`}
          fill="currentColor"
          viewBox="0 0 20 20"
          aria-hidden="true"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))
    }
  </div>

  <!-- Texto del review -->
  <p class="flex-1 text-slate-600 leading-relaxed text-sm line-clamp-5">
    {text}
  </p>

  <!-- Footer: avatar + nombre + Google -->
  <div class="flex items-center justify-between pt-3 border-t border-slate-100">
    <div class="flex items-center gap-3">
      <div
        class="w-9 h-9 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0"
        aria-hidden="true"
      >
        <span class="text-white text-xs font-semibold">{initials}</span>
      </div>
      <span class="text-sm font-semibold text-slate-900">{name}</span>
    </div>

    {
      url && (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs text-slate-500 hover:text-slate-700 transition-colors min-h-[44px] px-1"
          aria-label={`Ver reseña de ${name} en Google Maps`}
        >
          <!-- Google "G" logo SVG oficial -->
          <svg
            class="w-4 h-4 flex-shrink-0"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill="#4285F4"
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
            />
            <path
              fill="#34A853"
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
            />
            <path
              fill="#FBBC05"
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
            />
            <path
              fill="#EA4335"
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
            />
          </svg>
          <span>Google</span>
        </a>
      )
    }
  </div>
</article>
